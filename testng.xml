<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="QualityHR Suite">
    <listeners>
        <listener class-name="com.srm.qualityhr.listeners.TestListener"/>
    </listeners>

    <test name="Authentication Tests">
        <classes>
            <class name="com.srm.qualityhr.tests.AuthTests"/>
        </classes>
    </test>

    <test name="Employee Management Tests">
        <classes>
            <class name="com.srm.qualityhr.tests.EmployeeManagementTests"/>
        </classes>
    </test>

    <test name="Leave Management Tests">
        <classes>
            <class name="com.srm.qualityhr.tests.LeaveManagementTests"/>
        </classes>
    </test>

    <test name="User Role Management Tests">
        <classes>
            <class name="com.srm.qualityhr.tests.UserRoleManagementTests"/>
        </classes>
    </test>

    <test name="Form Validation Tests">
        <classes>
            <class name="com.srm.qualityhr.tests.FormValidationTests"/>
        </classes>
    </test>
</suite>
